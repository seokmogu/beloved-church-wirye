# Local development environment.
# Run the local Docker Postgres from docker-compose.yml before `pnpm dev`.
POSTGRES_URL=postgresql://postgres@localhost:54320/beloved-church-wirye

# Local frontend/admin URL. Use a Tailnet URL instead only when testing from another machine.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used by Payload to encrypt JWT/session data.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Secret used to authenticate Payload cron jobs.
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests.
PREVIEW_SECRET=YOUR_SECRET_HERE

# Optional local integrations.
NEXT_PUBLIC_CHAT_ENABLED=false
